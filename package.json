{
  "name": "maptalks-drawtool-customizable",
  "version": "1.0.0",
  "description": "maptalks DrawTool extension with self-intersection detection for polygon drawing",
  "main": "dist/maptalks-drawtool-customizable.cjs.js",
  "module": "dist/maptalks-drawtool-customizable.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w"
